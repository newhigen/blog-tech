---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/project/ProjectCard.astro';

const allProjects = await getCollection('projects');

function periodToNum(p?: string) {
  if (!p) return 0;
  const m = p.match(/(\d{4})\.(\d{2})/);
  return m ? parseInt(m[1]) * 100 + parseInt(m[2]) : 0;
}

const sortedProjects = [...allProjects].sort(
  (a, b) => periodToNum(b.data.period) - periodToNum(a.data.period)
);
---

<PageLayout title="Projects">
  <div class="projects-grid">
    {sortedProjects.map(project => (
      <ProjectCard
        title={project.data.title}
        slug={project.id}
        description={project.data.description}
        link={project.data.link}
        link2={project.data.link2}
        icon2={project.data.icon2}
        github={project.data.github}
        image={project.data.image}
        imageLight={project.data.imageLight}
        tags={project.data.tags}
        period={project.data.period}
        icon={project.data.icon}
      />
    ))}
    {sortedProjects.length === 0 && (
      <p style="color: var(--text-secondary);">No projects yet.</p>
    )}
  </div>
</PageLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    max-width: 64rem;
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: 42rem;
    }
  }

  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr;
      max-width: 32rem;
    }
  }
</style>
