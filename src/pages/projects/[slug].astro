---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: any;
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
---

<PageLayout title={project.data.title} description={project.data.description} headings={headings}>
  {project.data.dashboard && project.data.timeline ? (
    <div class="story-wrap">
      <div class="story-stage">
        <a class="dash-btn story-fs" href={project.data.dashboard} target="_blank" rel="noopener noreferrer">
          <span class="dash-btn-icon">↗</span><span class="dash-btn-label">전체화면</span>
        </a>
        <iframe src={project.data.dashboard} title={project.data.title} class="dashboard-frame story-pane" data-v="latest" loading="lazy" scrolling="yes" />
        {project.data.timeline.map((t: any, i: number) => (
          <img class="story-pane story-shot" data-v={String(i)} src={t.img} alt={t.label} hidden />
        ))}
      </div>
      <ol class="story-tl">
        {project.data.timeline.map((t: any, i: number) => (
          <li>
            <button class="tl-item" data-v={String(i)}>
              <span class="tl-mark"></span>
              <span class="tl-body"><b>{t.label}</b><span class="tl-intent">{t.intent}</span></span>
            </button>
          </li>
        ))}
        <li>
          <button class="tl-item active" data-v="latest">
            <span class="tl-mark tl-latest"></span>
            <span class="tl-body"><b>지금 · 라이브</b><span class="tl-intent">실제 동작하는 데모</span></span>
          </button>
        </li>
      </ol>
    </div>
  ) : project.data.dashboard ? (
    <div class="dashboard-wrap">
      <div class="dashboard-toolbar">
        <a class="dash-btn" href={project.data.dashboard} target="_blank" rel="noopener noreferrer">
          <span class="dash-btn-icon">↗</span><span class="dash-btn-label">전체화면으로 보기</span>
        </a>
      </div>
      <iframe
        src={project.data.dashboard}
        title={project.data.title}
        class="dashboard-frame"
        loading="lazy"
        scrolling="yes"
      />
    </div>
  ) : (project.data.image || project.data.imageLight) && (
    <div class="screenshot-wrap">
      {project.data.imageLight && (
        <img src={project.data.imageLight} alt={project.data.title} class="screenshot light-only" />
      )}
      {project.data.image && (
        <img
          src={project.data.image}
          alt={project.data.title}
          class={`screenshot${project.data.imageLight ? ' dark-only' : ''}`}
        />
      )}
    </div>
  )}

  <div class="meta-row">
    {project.data.link && (
      <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="meta-link">
        Visit →
      </a>
    )}
    {project.data.github && (
      <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="meta-link">
        GitHub →
      </a>
    )}
  </div>

  <article class="prose dark:prose-invert max-w-none">
    <Content />
  </article>
</PageLayout>

<style>
  .screenshot-wrap {
    margin-bottom: 2rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .screenshot {
    width: 100%;
    display: block;
  }

  .meta-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .meta-link {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    text-decoration: none;
  }

  .meta-link:hover {
    color: var(--text-secondary);
  }

  .dashboard-wrap {
    position: relative;
    margin-bottom: 2rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
  }

  .dashboard-toolbar {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 2;
    display: flex;
    gap: 6px;
  }

  .dash-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-size: 0.78rem;
    font-weight: 500;
    color: #f5f7fa;
    background: rgba(59, 130, 246, 0.92);
    border: 1px solid rgba(96, 165, 250, 0.6);
    border-radius: 6px;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
    transition: background 0.15s, transform 0.1s;
  }

  .dash-btn:hover {
    background: rgba(37, 99, 235, 1);
    transform: translateY(-1px);
  }

  .dash-btn-icon {
    font-size: 0.95rem;
    line-height: 1;
  }

  .dashboard-frame {
    width: 100%;
    height: 460px;
    border: none;
    display: block;
  }
  @media (max-width: 600px) {
    .dashboard-frame { height: 360px; }
  }

  :global(html.dark) .light-only { display: none; }
  :global(html:not(.dark)) .dark-only { display: none; }

  /* 프리뷰 + git-graph 타임라인 */
  .story-wrap { display: grid; grid-template-columns: 1.65fr 1fr; gap: 20px; margin-bottom: 2.25rem; align-items: start; }
  .story-stage { position: relative; border-radius: 12px; overflow: hidden; border: 1px solid var(--border); background: var(--bg-secondary); height: 470px; box-shadow: 0 10px 30px rgba(0,0,0,0.10), 0 2px 6px rgba(0,0,0,0.05); }
  :global(html.dark) .story-stage { box-shadow: 0 12px 32px rgba(0,0,0,0.45); }
  .story-pane { position: absolute; inset: 0; width: 100%; height: 100%; border: none; display: block; }
  img.story-shot { object-fit: cover; object-position: top center; }
  .story-fs { position: absolute; top: 10px; right: 10px; z-index: 3; }
  .story-tl { list-style: none; margin: 0; padding: 6px 0; position: relative; }
  .story-tl::before { content: ''; position: absolute; left: 14px; top: 26px; bottom: 30px; width: 2px; background: var(--border); }
  .tl-item { display: flex; gap: 14px; width: 100%; text-align: left; background: none; border: none; cursor: pointer; padding: 11px 12px; border-radius: 10px; align-items: flex-start; font: inherit; color: inherit; transition: background 0.15s; }
  .tl-item:hover { background: var(--code-bg); }
  .tl-item.active { background: var(--code-bg); }
  .tl-mark { flex-shrink: 0; width: 14px; height: 14px; border-radius: 50%; border: 2.5px solid var(--text-tertiary); background: var(--bg); margin-top: 3px; position: relative; z-index: 1; transition: 0.18s; }
  .tl-item:hover .tl-mark { border-color: var(--text-secondary); }
  .tl-item.active .tl-mark { border-color: #3b82f6; background: #3b82f6; box-shadow: 0 0 0 4px rgba(59,130,246,0.16); }
  .tl-item.active .tl-latest { animation: tl-pulse 2.2s ease-in-out infinite; }
  @keyframes tl-pulse { 0%,100% { box-shadow: 0 0 0 4px rgba(59,130,246,0.16); } 50% { box-shadow: 0 0 0 8px rgba(59,130,246,0.04); } }
  .tl-body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .tl-body b { font-size: 0.875rem; font-weight: 650; color: var(--text-secondary); letter-spacing: -0.01em; }
  .tl-item.active .tl-body b { color: var(--text-primary); }
  .tl-intent { font-size: 0.78rem; color: var(--text-tertiary); line-height: 1.5; }
  .tl-item.active .tl-intent { color: var(--text-secondary); }
  @media (max-width: 760px) { .story-wrap { grid-template-columns: 1fr; gap: 14px; } .story-stage { height: 340px; } .story-tl::before { display: none; } }
</style>

<script>
  // 블로그 테마(html.dark) ↔ 대시보드 iframe(data-theme) 동기화 (동일 출처)
  function initDashboardThemeSync() {
    const iframe = document.querySelector('.dashboard-frame') as HTMLIFrameElement | null;
    if (!iframe) return;
    const sync = () => {
      const dark = document.documentElement.classList.contains('dark');
      try {
        const doc = iframe.contentDocument;
        if (doc && doc.documentElement) {
          doc.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
          const btn = doc.querySelector('[class*="theme-toggle"]') as HTMLElement | null;
          if (btn) btn.style.display = 'none';
        }
      } catch (e) { /* cross-origin이면 무시 */ }
    };
    iframe.addEventListener('load', sync);
    try {
      if (iframe.contentDocument && iframe.contentDocument.readyState === 'complete') sync();
    } catch (e) {}
    new MutationObserver(sync).observe(document.documentElement, {
      attributes: true, attributeFilter: ['class'],
    });
  }
  document.addEventListener('astro:page-load', initDashboardThemeSync);
  initDashboardThemeSync();

  // 타임라인 클릭 → 프리뷰 전환 (최신=iframe, 과거=blur 스샷)
  function initStoryTimeline() {
    document.querySelectorAll<HTMLElement>('.story-wrap').forEach(wrap => {
      const panes = wrap.querySelectorAll<HTMLElement>('.story-pane');
      const items = wrap.querySelectorAll<HTMLElement>('.tl-item');
      items.forEach(it => it.addEventListener('click', () => {
        const v = it.dataset.v;
        panes.forEach(p => { (p as HTMLElement).hidden = p.dataset.v !== v; });
        items.forEach(i => i.classList.toggle('active', i === it));
      }));
    });
  }
  document.addEventListener('astro:page-load', initStoryTimeline);
  initStoryTimeline();
</script>
