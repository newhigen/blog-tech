---
interface Props {
  title: string;
  slug: string;
  description: string;
  period?: string;
  icon?: string;
  image?: string;
  imageLight?: string;
  category?: string;
  variant?: 'list' | 'minimal';
}

const { title, slug, description, period, icon, image, imageLight, category, variant = 'list' } = Astro.props;
const href = '/projects/' + slug;
const previewDark = image || imageLight || '';
const previewLight = imageLight || image || '';

// period가 일(日)까지 있으면(YYYY.MM.DD) 요일을 계산해 "(요일)"을 붙인다. 월 단위(YYYY.MM)는 그대로.
const WD = ['일', '월', '화', '수', '목', '금', '토'];
function periodLabel(p?: string): string | undefined {
  if (!p) return p;
  const m = p.match(/^(\d{4})\.(\d{2})\.(\d{2})$/);
  if (!m) return p;
  const d = new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
  return `${p} (${WD[d.getDay()]})`;
}
const periodText = periodLabel(period);
---

{variant === 'minimal' ? (
  <a class='project-min' href={href}>
    {icon && <span class='min-icon'>{icon}</span>}
    <span class='min-title'>{title}</span>
    <span class='min-dots'>·····························································································································································</span>
    {periodText && <span class='min-period'>{periodText}</span>}
  </a>
) : (
  <a
    class='project-item'
    href={href}
    data-category={category}
    data-img-dark={previewDark}
    data-img-light={previewLight}
  >
    {icon && <span class='pi-icon'>{icon}</span>}
    <span class='pi-title'>{title}</span>
    <span class='pi-desc'>{description}</span>
    {periodText && <span class='pi-period'>{periodText}</span>}
  </a>
)}

<style>
  /* ── minimal (home) ── */
  .project-min {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
    text-decoration: none;
  }
  .min-icon { color: var(--text-tertiary); flex-shrink: 0; width: 1.1rem; text-align: center; }
  .min-title {
    font-size: 0.875rem;
    color: var(--text-primary);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    flex-shrink: 1; min-width: 0;
    transition: opacity 0.15s ease;
  }
  .min-title:hover { opacity: 0.6; }
  .min-dots {
    flex: 1 1 2rem; min-width: 2rem; overflow: hidden;
    letter-spacing: 5px; color: var(--text-tertiary); opacity: 0.5;
    pointer-events: none; white-space: nowrap; line-height: 1.5rem; height: 1.5rem;
  }
  .min-period { font-size: 0.75rem; color: var(--text-tertiary); white-space: nowrap; flex-shrink: 0; }

  /* ── list (projects page): text row + hover preview ── */
  .project-item {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .project-item:hover { background: var(--selection); }
  .pi-icon { color: var(--text-tertiary); flex-shrink: 0; width: 1.2rem; text-align: center; }
  .pi-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .pi-desc {
    font-size: 0.825rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1 1 auto;
    min-width: 0;
  }
  .pi-period {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (max-width: 600px) {
    .pi-desc { display: none; }
  }
</style>
