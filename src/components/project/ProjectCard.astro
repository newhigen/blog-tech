---
interface Props {
  title: string;
  slug: string;
  description: string;
  period?: string;
  icon?: string;
  image?: string;
  imageLight?: string;
  category?: string;
}

const { title, slug, description, period, icon, image, imageLight, category } = Astro.props;
const href = '/projects/' + slug;
---

<article class='project-row' data-href={href} data-category={category}>
  <div class='thumb'>
    {(image || imageLight) ? (
      <>
        {imageLight && <img src={imageLight} alt={title} class='thumb-img light-only' loading='lazy' />}
        {image && <img src={image} alt={title} class={'thumb-img' + (imageLight ? ' dark-only' : '')} loading='lazy' />}
      </>
    ) : (
      <span class='thumb-icon'>{icon || '📁'}</span>
    )}
  </div>

  <div class='row-body'>
    <div class='row-head'>
      <h2 class='title'>{title}</h2>
      {period && <span class='period'>{period}</span>}
    </div>
    <p class='description'>{description}</p>
  </div>
</article>

<script>
  import { navigate } from 'astro:transitions/client';

  function initRows() {
    document.querySelectorAll('[data-href].project-row').forEach(row => {
      if ((row as HTMLElement).dataset.bound) return;
      (row as HTMLElement).dataset.bound = '1';
      row.addEventListener('click', (e) => {
        if ((e.target as Element).closest('a')) return;
        const href = (row as HTMLElement).dataset.href;
        if (href) navigate(href);
      });
    });
  }

  document.addEventListener('astro:page-load', initRows);
</script>

<style>
  .project-row {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1rem 0;
    cursor: pointer;
    border-bottom: 1px solid var(--border);
  }
  .project-row:last-child { border-bottom: none; }

  .thumb {
    flex-shrink: 0;
    width: 116px;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    border: 1px solid var(--border);
    overflow: hidden;
    background: var(--selection);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.25s ease;
  }
  .thumb-icon { font-size: 1.6rem; opacity: 0.6; }
  .project-row:hover .thumb-img { transform: scale(1.04); }

  .row-body { flex: 1; min-width: 0; }
  .row-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
  }
  .title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    transition: opacity 0.15s ease;
  }
  .project-row:hover .title { opacity: 0.6; }
  .period {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    white-space: nowrap;
  }
  .description {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .thumb { width: 88px; }
    .project-row { gap: 0.85rem; }
  }

  :global(html.dark) .light-only { display: none; }
  :global(html:not(.dark)) .dark-only { display: none; }
</style>
