---
interface Props {
  title: string;
  slug: string;
  description: string;
  link?: string;
  link2?: string;
  icon2?: string;
  github?: string;
  tags?: string[];
  period?: string;
  icon?: string;
  image?: string;
  imageLight?: string;
  compact?: boolean;
}

const { title, slug, description, link, link2, icon2, github, tags = [], period, icon, image, imageLight, compact = false } = Astro.props;
const href = '/projects/' + slug;
---

{compact ? (
  <a class='project-compact' href={href}>
    {icon && <span class='compact-icon'>{icon}</span>}
    <span class='compact-title'>{title}</span>
    <span class='compact-sep'>—</span>
    <span class='compact-desc'>{description}</span>
  </a>
) : (
  <article class='project-card' data-href={href}>
    <div class='preview-container'>
      {(image || imageLight) ? (
        <div class='preview-wrap'>
          {imageLight && <img src={imageLight} alt={title} class='preview-image light-only' loading='lazy' />}
          {image && <img src={image} alt={title} class={'preview-image' + (imageLight ? ' dark-only' : '')} loading='lazy' />}
        </div>
      ) : (
        <div class='placeholder-wrap'>
          <span class='big-icon'>{icon || '📁'}</span>
        </div>
      )}
      {period && (
        <div class='period-badge-wrap'>
          <span class='period-badge'>{period}</span>
        </div>
      )}
    </div>

    <div class='card-content'>
      <h2 class='title'>{title}</h2>
      <p class='description'>{description}</p>
    </div>

    <div class='arrow' aria-hidden='true'>
    </div>
  </article>
)}

<script>
  import { navigate } from 'astro:transitions/client';

  function initCards() {
    const cards = document.querySelectorAll('[data-href].project-card');
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as Element;
        if (target.closest('a')) return;
        const href = (card as HTMLElement).dataset.href;
        if (href) navigate(href);
      });
    });
  }

  document.addEventListener('astro:page-load', initCards);
</script>

<style>
  .project-compact { display: flex; align-items: baseline; gap: 0.5rem; font-size: 0.875rem; color: var(--text-primary); text-decoration: none; padding: 0.4rem 0; transition: opacity 0.2s ease; }
  .project-compact:hover { opacity: 0.6; }
  .compact-icon { color: var(--text-tertiary); flex-shrink: 0; }
  .compact-title { font-weight: 600; flex-shrink: 0; }
  .compact-desc { color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-card, var(--bg));
    border-radius: 12px;
    border: 1px solid var(--border);
    cursor: pointer;
    overflow: hidden;
    transition: all 0.2s ease;
  }
  .project-card:hover { border-color: var(--text-tertiary); background: var(--selection); }

  .preview-container { position: relative; width: 100%; aspect-ratio: 16 / 10; overflow: hidden; background: var(--selection); border-bottom: 1px solid var(--border); }
  .preview-image { width: 100%; height: 100%; object-fit: cover; }
  .placeholder-wrap { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
  .big-icon { font-size: 3rem; opacity: 0.8; }

  .period-badge-wrap { position: absolute; top: 12px; left: 12px; z-index: 10; }
  .period-badge { padding: 2px 8px; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; font-size: 0.7rem; font-weight: 500; color: var(--text-secondary); }

  .card-content { padding: 1rem; flex: 1; display: flex; flex-direction: column; }
  .title { font-size: 0.95rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.5rem; }
  .description { font-size: 0.85rem; line-height: 1.5; color: var(--text-secondary); margin: 0; }

  

  :global(html.dark) .light-only { display: none; }
  :global(html:not(.dark)) .dark-only { display: none; }
</style>